{
  "manifest_version": 3,
  "name": "wonderh-ai-manager",
  "version": "1.2.2",
  "description": "REXOW Local-First AI Manager",
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "permissions": [
    "nativeMessaging",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://gemini.google.com/*",
    "*://claude.ai/*"
  ],
  "background": {
    "scripts": [
      "entrypoints/background.js"
    ]
  },
  "action": {
    "default_title": "Open REXOW Dashboard",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://claude.ai/*"
      ],
      "js": [
        "entrypoints/content_extractor.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "entrypoints/adapters/chatgpt.js",
        "entrypoints/adapters/gemini.js",
        "entrypoints/adapters/claude.js"
      ],
      "matches": [
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://claude.ai/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "wonderh-ai@manager.local"
    }
  }
}