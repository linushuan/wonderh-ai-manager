{
  "name": "wonderh-ai-manager",
  "version": "1.2.0",
  "description": "REXOW Local-First AI Manager",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest test",
    "test:integration": "jest test/integration",
    "build:firefox": "web-ext build --overwrite-dest",
    "sign:firefox": "web-ext sign --api-key=$AMO_JWT_ISSUER --api-secret=$AMO_JWT_SECRET"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@jest/globals": "^29.0.0",
    "babel-jest": "^30.2.0",
    "jest": "^29.0.0",
    "jest-chrome": "^0.8.0",
    "jest-environment-jsdom": "^30.2.0",
    "web-ext": "^9.4.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^chrome$": "jest-chrome"
    },
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "collectCoverageFrom": [
      "entrypoints/**/*.js",
      "!entrypoints/dashboard.html"
    ]
  },
  "dependencies": {
    "katex": "^0.16.33",
    "marked": "^17.0.3",
    "marked-katex-extension": "^5.1.7"
  }
}
